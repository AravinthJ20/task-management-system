<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}} | Task Manager</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <style>
      :root {
        --bg: #f5efe4;
        --bg-accent: #efe3d1;
        --surface: rgba(255, 252, 246, 0.78);
        --surface-strong: #fffdf8;
        --ink: #1f2933;
        --muted: #607081;
        --line: rgba(114, 92, 55, 0.14);
        --brand: #0f766e;
        --brand-deep: #115e59;
        --brand-soft: #d7f4ee;
        --gold: #c08a2e;
        --danger-soft: #fbe4df;
        --shadow: 0 22px 60px rgba(56, 41, 19, 0.12);
        --radius-lg: 28px;
        --radius-md: 18px;
        --radius-sm: 12px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        color: var(--ink);
        font-family: 'DM Sans', sans-serif;
        background:
          radial-gradient(circle at top left, rgba(15, 118, 110, 0.10), transparent 32%),
          radial-gradient(circle at top right, rgba(192, 138, 46, 0.16), transparent 30%),
          linear-gradient(180deg, #fcfaf5 0%, var(--bg) 100%);
      }

      h1, h2, h3, h4, h5, .navbar-brand {
        font-family: 'Space Grotesk', sans-serif;
        letter-spacing: -0.03em;
      }

      a {
        color: var(--brand-deep);
        text-decoration: none;
      }

      a:hover {
        color: var(--brand);
      }

      .app-shell {
        position: relative;
        padding: 28px 0 56px;
      }

      .app-shell::before,
      .app-shell::after {
        content: '';
        position: fixed;
        z-index: -1;
        border-radius: 999px;
        filter: blur(12px);
        opacity: 0.55;
      }

      .app-shell::before {
        top: 84px;
        left: -60px;
        width: 220px;
        height: 220px;
        background: rgba(15, 118, 110, 0.12);
      }

      .app-shell::after {
        right: -30px;
        bottom: 40px;
        width: 260px;
        height: 260px;
        background: rgba(192, 138, 46, 0.12);
      }

      .navbar.app-navbar {
        background: rgba(23, 37, 45, 0.88) !important;
        backdrop-filter: blur(14px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        box-shadow: var(--shadow);
        margin-bottom: 28px;
      }

      .navbar-brand {
        font-size: 1.2rem;
        color: #fff7e8 !important;
      }

      .nav-link {
        color: rgba(255, 247, 232, 0.82) !important;
      }

      .nav-link:hover,
      .nav-link:focus {
        color: #ffffff !important;
      }

      .nav-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-radius: 999px;
        transition: background-color 0.2s ease, transform 0.2s ease;
      }

      .nav-pill:hover {
        background: rgba(255, 255, 255, 0.08);
        transform: translateY(-1px);
      }

      .main-frame {
        background: var(--surface);
        border: 1px solid rgba(255, 255, 255, 0.65);
        border-radius: 32px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(12px);
        padding: 32px;
      }

      .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 18px;
        margin-bottom: 26px;
      }

      .page-eyebrow {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        background: var(--brand-soft);
        color: var(--brand-deep);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 14px;
      }

      .page-title {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3rem);
      }

      .page-subtitle {
        margin: 10px 0 0;
        color: var(--muted);
        max-width: 680px;
        font-size: 1.02rem;
      }

      .btn {
        border-radius: 999px;
        padding: 0.72rem 1.25rem;
        font-weight: 700;
        border: none;
      }

      .btn-primary,
      .btn-success {
        background: linear-gradient(135deg, var(--brand) 0%, #169487 100%);
        box-shadow: 0 12px 22px rgba(15, 118, 110, 0.18);
      }

      .btn-primary:hover,
      .btn-success:hover {
        background: linear-gradient(135deg, var(--brand-deep) 0%, var(--brand) 100%);
      }

      .btn-secondary {
        background: #e5dccb;
        color: var(--ink);
      }

      .btn-outline-secondary {
        border: 1px solid var(--line);
        color: var(--ink);
        background: rgba(255, 255, 255, 0.72);
      }

      .btn-danger {
        background: #b7402b;
      }

      .btn-link.nav-link {
        padding: 10px 14px;
      }

      .card,
      .panel-card,
      .info-card,
      .form-card {
        background: var(--surface-strong);
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        box-shadow: 0 14px 34px rgba(80, 60, 26, 0.08);
      }

      .panel-card,
      .info-card,
      .form-card {
        padding: 24px;
      }

      .metric-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin-bottom: 26px;
      }

      .metric-card {
        padding: 22px;
        border-radius: 24px;
        background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(251, 246, 238, 0.95));
        border: 1px solid var(--line);
      }

      .metric-label {
        color: var(--muted);
        font-size: 0.92rem;
        margin-bottom: 8px;
      }

      .metric-value {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2rem;
        line-height: 1;
      }

      .table-shell {
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 24px;
        background: var(--surface-strong);
      }

      .table {
        margin-bottom: 0;
      }

      .table > :not(caption) > * > * {
        padding: 1rem 1.1rem;
        border-bottom-color: rgba(114, 92, 55, 0.08);
        vertical-align: middle;
      }

      .table thead th {
        background: #f6efe2;
        color: #4a5966;
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        border-bottom: none;
      }

      .table tbody tr:hover {
        background: rgba(15, 118, 110, 0.04);
      }

      .status-pill,
      .role-pill,
      .date-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.42rem 0.8rem;
        font-size: 0.84rem;
        font-weight: 700;
      }

      .status-todo {
        background: #e8f0ff;
        color: #285ea8;
      }

      .status-progress {
        background: #fff2d6;
        color: #9b6200;
      }

      .status-completed {
        background: #dff5e7;
        color: #23794a;
      }

      .status-blocked {
        background: var(--danger-soft);
        color: #a63a25;
      }

      .status-neutral,
      .role-pill,
      .date-pill {
        background: #ece7df;
        color: #586775;
      }

      .list-clean {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .list-clean li + li {
        margin-top: 12px;
      }

      .project-row,
      .task-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding: 16px 18px;
        border-radius: var(--radius-md);
        background: rgba(247, 241, 232, 0.6);
      }

      .project-row strong,
      .task-row strong {
        display: block;
        margin-bottom: 4px;
      }

      .muted {
        color: var(--muted);
      }

      .form-card .form-control,
      .form-card .form-select {
        border-radius: 16px;
        border: 1px solid rgba(100, 88, 62, 0.18);
        padding: 0.85rem 1rem;
        background: #fffdfa;
      }

      .form-card .form-control:focus,
      .form-card .form-select:focus {
        border-color: rgba(15, 118, 110, 0.45);
        box-shadow: 0 0 0 0.25rem rgba(15, 118, 110, 0.14);
      }

      .auth-shell {
        min-height: calc(100vh - 180px);
        display: flex;
        align-items: center;
      }

      .empty-state {
        padding: 38px 24px;
        border: 1px dashed rgba(96, 112, 129, 0.35);
        border-radius: 24px;
        text-align: center;
        background: rgba(255, 255, 255, 0.55);
        color: var(--muted);
      }

      @media (max-width: 991.98px) {
        .main-frame {
          padding: 24px;
          border-radius: 24px;
        }

        .metric-grid {
          grid-template-columns: 1fr;
        }

        .page-header {
          flex-direction: column;
          align-items: flex-start;
        }

        .navbar.app-navbar {
          border-radius: 18px;
        }
      }

      @media (max-width: 767.98px) {
        .app-shell {
          padding-top: 18px;
        }

        .main-frame {
          padding: 18px;
        }

        .table-shell {
          overflow-x: auto;
        }

        .project-row,
        .task-row {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <div class="container app-shell">
      <nav class="navbar navbar-expand-lg navbar-dark app-navbar px-3 px-lg-4">
        <a class="navbar-brand" href="/">Task Manager</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#appNav" aria-controls="appNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="appNav">
          <ul class="navbar-nav ms-auto">
            {{#if isAuthenticated}}
              <li class="nav-item"><a class="nav-link nav-pill" href="/projects">Projects</a></li>
              <li class="nav-item"><a class="nav-link nav-pill" href="/tasks">Tasks</a></li>
              <li class="nav-item"><a class="nav-link nav-pill" href="/users">Users</a></li>
              <li class="nav-item"><span class="nav-link nav-pill">Signed in as {{currentUser.name}}</span></li>
              <li class="nav-item">
                <form action="/auth/logout" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-link nav-link nav-pill">Logout</button>
                </form>
              </li>
            {{else}}
              <li class="nav-item"><a class="nav-link nav-pill" href="/auth/login">Login</a></li>
              <li class="nav-item"><a class="nav-link nav-pill" href="/auth/register">Register</a></li>
            {{/if}}
          </ul>
        </div>
      </nav>
      <main class="main-frame">
        {{{body}}}
      </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
