<section class="page-header">
  <div>
    <span class="page-eyebrow">New Task</span>
    <h1 class="page-title">Create an assignment</h1>
    <p class="page-subtitle">Define the work clearly, place it in the right project, and assign ownership before it slips through the cracks.</p>
  </div>
</section>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <form action="/tasks" method="POST" class="form-card">
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input type="text" name="title" class="form-control" required />
      </div>
      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="description" class="form-control" rows="5" placeholder="Describe the expected outcome, context, and anything the assignee should know."></textarea>
      </div>
      <div class="mb-3">
        <label class="form-label">Project</label>
        <select name="project" class="form-select" required>
          <option value="">Select a project</option>
          {{#each projects}}
            <option value="{{this._id}}">{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label">Assign To</label>
        <select name="assignedTo" class="form-select">
          <option value="">Unassigned</option>
          {{#each users}}
            <option value="{{this._id}}">{{this.name}} ({{this.email}})</option>
          {{/each}}
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
          <option>Todo</option>
          <option>In Progress</option>
          <option>Completed</option>
          <option>Blocked</option>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label">Due Date</label>
        <input type="date" name="dueDate" class="form-control" />
      </div>
      <button type="submit" class="btn btn-success">Create Task</button>
    </form>
  </div>
</div>
