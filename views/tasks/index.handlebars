<section class="page-header">
  <div>
    <span class="page-eyebrow">Tasks</span>
    <h1 class="page-title">Work queue</h1>
    <p class="page-subtitle">Monitor assignment flow, track status changes, and keep every task connected to the right project.</p>
  </div>
  <a class="btn btn-primary" href="/tasks/new">New Task</a>
</section>
{{#if tasks.length}}
  <div class="table-shell">
    <table class="table">
      <thead>
        <tr><th>Title</th><th>Project</th><th>Status</th><th>Assigned</th><th>Due</th><th>Actions</th></tr>
      </thead>
      <tbody>
        {{#each tasks}}
          <tr>
            <td>
              <strong>{{this.title}}</strong>
              <div class="muted">{{this.description}}</div>
            </td>
            <td>{{this.project.name}}</td>
            <td><span class="status-pill {{statusClass this.status}}">{{this.status}}</span></td>
            <td>{{#if this.assignedTo}}{{this.assignedTo.name}}{{else}}<span class="muted">Unassigned</span>{{/if}}</td>
            <td><span class="date-pill">{{formatDate this.dueDate}}</span></td>
            <td>
              <a href="/tasks/{{this._id}}/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
              <form action="/tasks/{{this._id}}?_method=DELETE" method="POST" class="d-inline">
                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
{{else}}
  <div class="empty-state">No tasks yet. Add a task to start distributing work across your team.</div>
{{/if}}
