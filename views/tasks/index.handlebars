<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Tasks</h1>
  <a class="btn btn-primary" href="/tasks/new">New Task</a>
</div>
{{#if tasks.length}}
  <table class="table table-striped">
    <thead>
      <tr><th>Title</th><th>Project</th><th>Status</th><th>Assigned</th><th>Actions</th></tr>
    </thead>
    <tbody>
      {{#each tasks}}
        <tr>
          <td>{{this.title}}</td>
          <td>{{this.project.name}}</td>
          <td>{{this.status}}</td>
          <td>{{#if this.assignedTo}}{{this.assignedTo.name}}{{else}}Unassigned{{/if}}</td>
          <td>
            <a href="/tasks/{{this._id}}/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
            <form action="/tasks/{{this._id}}?_method=DELETE" method="POST" class="d-inline">
              <button type="submit" class="btn btn-sm btn-danger">Delete</button>
            </form>
          </td>
        </tr>
      {{/each}}
    </tbody>
  </table>
{{else}}
  <p>No tasks yet.</p>
{{/if}}
