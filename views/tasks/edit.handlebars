<section class="page-header">
  <div>
    <span class="page-eyebrow">Edit Task</span>
    <h1 class="page-title">Refine task details</h1>
    <p class="page-subtitle">Update ownership, status, and timing so the board always reflects the real state of work.</p>
  </div>
</section>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <form action="/tasks/{{task._id}}?_method=PUT" method="POST" class="form-card">
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input type="text" name="title" class="form-control" value="{{task.title}}" required />
      </div>
      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="description" class="form-control" rows="5">{{task.description}}</textarea>
      </div>
      <div class="mb-3">
        <label class="form-label">Project</label>
        <select name="project" class="form-select" required>
          {{#each projects}}
            <option value="{{this._id}}" {{#ifEquals this._id ../task.project}}selected{{/ifEquals}}>{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label">Assign To</label>
        <select name="assignedTo" class="form-select">
          <option value="">Unassigned</option>
          {{#each users}}
            <option value="{{this._id}}" {{#ifEquals this._id ../task.assignedTo}}selected{{/ifEquals}}>{{this.name}} ({{this.email}})</option>
          {{/each}}
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
          <option {{#ifEquals 'Todo' task.status}}selected{{/ifEquals}}>Todo</option>
          <option {{#ifEquals 'In Progress' task.status}}selected{{/ifEquals}}>In Progress</option>
          <option {{#ifEquals 'Completed' task.status}}selected{{/ifEquals}}>Completed</option>
          <option {{#ifEquals 'Blocked' task.status}}selected{{/ifEquals}}>Blocked</option>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label">Due Date</label>
        <input type="date" name="dueDate" class="form-control" value="{{formatDateInput task.dueDate}}" />
      </div>
      <button type="submit" class="btn btn-primary">Update Task</button>
    </form>
  </div>
</div>
