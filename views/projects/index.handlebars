<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Projects</h1>
  <a class="btn btn-primary" href="/projects/new">New Project</a>
</div>
{{#if projects.length}}
  <table class="table table-striped">
    <thead>
      <tr><th>Name</th><th>Created</th><th></th></tr>
    </thead>
    <tbody>
      {{#each projects}}
        <tr>
          <td><a href="/projects/{{this._id}}">{{this.name}}</a></td>
          <td>{{this.createdAt}}</td>
          <td><a href="/projects/{{this._id}}" class="btn btn-sm btn-outline-secondary">View</a></td>
        </tr>
      {{/each}}
    </tbody>
  </table>
{{else}}
  <p>No projects yet. Create one now.</p>
{{/if}}
