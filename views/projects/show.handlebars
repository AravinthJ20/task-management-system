<section class="page-header">
  <div>
    <span class="page-eyebrow">Project Detail</span>
    <h1 class="page-title">{{project.name}}</h1>
    <p class="page-subtitle">{{project.description}}</p>
  </div>
  <a href="/tasks/new" class="btn btn-primary">Create Task</a>
</section>

<section class="panel-card">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h2 class="h3 mb-1">Task list</h2>
      <p class="muted mb-0">Everything currently attached to this project.</p>
    </div>
    <span class="date-pill">{{tasks.length}} tasks</span>
  </div>
{{#if tasks.length}}
  <div class="table-shell">
    <table class="table">
      <thead>
        <tr><th>Title</th><th>Status</th><th>Assigned To</th><th>Due</th></tr>
      </thead>
      <tbody>
        {{#each tasks}}
          <tr>
            <td>
              <strong>{{this.title}}</strong>
              <div class="muted">{{this.description}}</div>
            </td>
            <td><span class="status-pill {{statusClass this.status}}">{{this.status}}</span></td>
            <td>{{#if this.assignedTo}}{{this.assignedTo.name}}{{else}}<span class="muted">Unassigned</span>{{/if}}</td>
            <td><span class="date-pill">{{formatDate this.dueDate}}</span></td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
{{else}}
  <div class="empty-state">No tasks for this project yet. Add the first task to turn this project into an executable plan.</div>
{{/if}}
</section>
