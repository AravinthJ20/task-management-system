<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1>{{project.name}}</h1>
    <p>{{project.description}}</p>
  </div>
  <a href="/tasks/new" class="btn btn-primary">Create Task</a>
</div>
<h2>Tasks</h2>
{{#if tasks.length}}
  <table class="table table-bordered">
    <thead>
      <tr><th>Title</th><th>Status</th><th>Assigned To</th><th>Due</th></tr>
    </thead>
    <tbody>
      {{#each tasks}}
        <tr>
          <td>{{this.title}}</td>
          <td>{{this.status}}</td>
          <td>{{#if this.assignedTo}}{{this.assignedTo.name}}{{else}}Unassigned{{/if}}</td>
          <td>{{this.dueDate}}</td>
        </tr>
      {{/each}}
    </tbody>
  </table>
{{else}}
  <p>No tasks for this project yet.</p>
{{/if}}
